<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/choose_pet"
        android:textSize="18sp"
        android:textColor="#333"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgPetType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/rbCat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🐱 猫猫"
            android:textSize="16sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbDog"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🐶 狗狗"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbBunny"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🐰 兔子"
            android:textSize="16sp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/speed"
        android:textSize="18sp"
        android:textColor="#333"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/sbSpeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10"
        android:progress="5"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/idle_time"
        android:textSize="18sp"
        android:textColor="#333"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/sbIdleTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="30"
        android:progress="10"
        android:layout_marginBottom="32dp" />

    <CheckBox
        android:id="@+id/cbAutoStart"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/auto_start"
        android:textSize="16sp" />

</LinearLayout>
